node {

    def REPO_URL       = env.REPO_URL       ?: "https://github.com/mukeshdevelp/ot-microservice-sarthi.git"
    def BRANCH         = env.BRANCH         ?: "backend"
    def PROJECT_KEY    = env.PROJECT_KEY    ?: "golang-bug-analysis-mukesh-2"
    def SONAR_HOST_URL = env.SONAR_HOST_URL ?: "http://192.168.8.17:9000"
    def EMAIL_TO       = env.EMAIL_TO       ?: "devopsp491@gmail.com"
    def SLACK_CHANNEL  = env.SLACK_CHANNEL  ?: "#ci-operation-notifications"

    def SCANNER_HOME = tool 'sonar-scanner'
    def GO_DIR       = "${WORKSPACE}/tools/go"
    def GO_BIN       = "${GO_DIR}/bin"

    try {

        stage('Clean Workspace') {
            try {
                deleteDir()
            } catch (e) {
                error "Workspace cleanup failed: ${e}"
            }
        }

        stage('Checkout Code') {
            try {
                git url: REPO_URL, branch: BRANCH
            } catch (e) {
                error "Checkout failed: ${e}"
            }
        }

        stage('Setup Go') {
            try {
                sh """
                    set -e
                    if [ ! -d "${GO_DIR}" ]; then
                        mkdir -p ${GO_DIR}
                        wget -q https://go.dev/dl/go1.21.7.linux-amd64.tar.gz -O /tmp/go.tar.gz
                        tar -C ${GO_DIR} -xzf /tmp/go.tar.gz --strip-components=1
                        rm -f /tmp/go.tar.gz
                    fi
                """

                env.PATH = "${GO_BIN}:${env.PATH}"

                sh 'go version'

            } catch (e) {
                error "Go setup failed: ${e}"
            }
        }

        stage('Debug Workspace') {
            try {
                sh '''
                    pwd
                    ls -la
                '''
            } catch (e) {
                error "Debug failed: ${e}"
            }
        }

        stage('Go Build') {
            try {
                dir('employee/employee-api') {
                    sh '''
                        set -e
                        go mod tidy
                        go build ./...
                    '''
                }
            } catch (e) {
                error "Go build failed: ${e}"
            }
        }

        stage('Go Unit Tests') {
            try {
                dir('employee/employee-api') {
                    sh '''
                        set -e
                        go test ./... | tee test-results.txt
                    '''
                }
            } catch (e) {
                error "Unit tests failed: ${e}"
            }
        }

        stage('Generate Coverage') {
            try {
                dir('employee/employee-api') {
                    sh '''
                        set -e
                        export GOPATH=$HOME/go
                        export GOCACHE=$WORKSPACE/.cache/go-build

                        go test ./... \
                            -coverprofile=coverage.out \
                            -covermode=atomic
                    '''
                }
            } catch (e) {
                error "Coverage generation failed: ${e}"
            }
        }

        stage('Setup Java') {
            try {
                script {
                    def javaHome = tool name: 'jdk17', type: 'jdk'
                    env.JAVA_HOME = javaHome
                    env.PATH = "${javaHome}/bin:${env.PATH}"
                }
                sh 'java -version'
            } catch (e) {
                error "Java setup failed: ${e}"
            }
        }

        stage('SonarQube Analysis') {
            try {
                withSonarQubeEnv('SonarQube') {
                    withCredentials([string(credentialsId: 'sonar-token-golang-bug-analysis', variable: 'SONAR_LOGIN')]) {

                        dir('employee/employee-api') {
                            sh """
                                ${SCANNER_HOME}/bin/sonar-scanner \
                                    -Dsonar.projectKey=${PROJECT_KEY} \
                                    -Dsonar.projectName=${PROJECT_KEY} \
                                    -Dsonar.sources=. \
                                    -Dsonar.tests=. \
                                    -Dsonar.test.inclusions=**/*_test.go \
                                    -Dsonar.go.coverage.reportPaths=coverage.out \
                                    -Dsonar.host.url=${SONAR_HOST_URL} \
                                    -Dsonar.login=${SONAR_LOGIN}
                            """
                        }
                    }
                }
            } catch (e) {
                error "SonarQube analysis failed: ${e}"
            }
        }

        stage('Quality Gate') {
            try {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            } catch (e) {
                error "Quality Gate failed: ${e}"
            }
        }

        stage('Success') {
            currentBuild.result = 'SUCCESS'
            echo "Pipeline executed successfully"
        }

    } catch (Exception e) {
        currentBuild.result = 'FAILURE'
        echo "Pipeline Failed: ${e.getMessage()}"
        throw e

    } finally {

        stage('Notifications') {
            script {
                def status = currentBuild.result ?: 'SUCCESS'
                def color  = (status == 'SUCCESS') ? 'good' : 'danger'

                try {
                    slackSend(
                        channel: SLACK_CHANNEL,
                        color: color,
                        message: """
                        *Go CI Pipeline*

                        Status: ${status}
                        Repo: ${REPO_URL}
                        Branch: ${BRANCH}
                        Job: ${env.JOB_NAME}
                        Build: #${env.BUILD_NUMBER}
                        URL: ${env.BUILD_URL}
                        """
                    )
                } catch (e) {
                    echo "Slack failed: ${e}"
                }

                try {
                    emailext(
                        subject: "Build ${status}: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                        body: """
                        Status: ${status}

                        Repo: ${REPO_URL}
                        Branch: ${BRANCH}

                        Build URL:
                        ${env.BUILD_URL}
                        """,
                        to: EMAIL_TO
                    )
                } catch (e) {
                    echo "Email failed: ${e}"
                }
            }
        }

        stage('Archive') {
            archiveArtifacts artifacts: 'employee/employee-api/coverage.out, employee/employee-api/test-results.txt',
                             allowEmptyArchive: true,
                             fingerprint: true
        }

        stage('Cleanup') {
            cleanWs()
        }
    }
}
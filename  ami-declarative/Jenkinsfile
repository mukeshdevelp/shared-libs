pipeline {
    agent any

    environment {
        AMI_ID          = "ami-0ee5e6f2f964f34e5"
        INSTANCE_TYPE   = "t2.micro"
        KEY_NAME        = "ot_micro_service"
        PEM_FILE        = "/var/lib/jenkins/ot_micro_service.pem"
        REGION          = "ap-south-1"
        SECURITY_GROUP  = "sg-04bcfb0bec44ad33e"
        SUBNET_ID       = "subnet-0ce4198e3ed718046"
        TRIVY_REPORT    = "trivy-report.json"
        SLACK_CHANNEL   = "#ci-operation-notifications"
    }   

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Launch EC2') {
            steps {
                script {
                    echo "Launching EC2..."
                    env.INSTANCE_ID = sh(
                        script: """
                            aws ec2 run-instances \
                            --image-id ${env.AMI_ID} \
                            --instance-type ${env.INSTANCE_TYPE} \
                            --key-name ${env.KEY_NAME} \
                            --security-group-ids ${env.SECURITY_GROUP} \
                            --subnet-id ${env.SUBNET_ID} \
                            --associate-public-ip-address \
                            --query 'Instances[0].InstanceId' \
                            --output text \
                            --region ${env.REGION}
                        """,
                        returnStdout: true
                    ).trim()

                    if (!env.INSTANCE_ID) {
                        error("Failed to launch EC2 instance")
                    }
                    echo "Instance ID: ${env.INSTANCE_ID}"
                }
            }
        }

        stage('Wait for Instance') {
            steps {
                sh """
                    aws ec2 wait instance-running \
                    --instance-ids ${env.INSTANCE_ID} \
                    --region ${env.REGION}
                """
            }
        }

        stage('Get Public IP') {
            steps {
                script {
                    env.PUBLIC_IP = sh(
                        script: """
                            aws ec2 describe-instances \
                            --instance-ids ${env.INSTANCE_ID} \
                            --query 'Reservations[0].Instances[0].PublicIpAddress' \
                            --output text \
                            --region ${env.REGION}
                        """,
                        returnStdout: true
                    ).trim()
                    echo "Public IP: ${env.PUBLIC_IP}"
                    echo "Waiting for SSH to be ready..."
                    sleep 60
                }
            }
        }

        

        stage('SSH Check') {
            steps {
                retry(5) {
                    sh """
                        ssh -i ${env.PEM_FILE} \
                        -o StrictHostKeyChecking=no \
                        -o ConnectTimeout=10 \
                        ubuntu@${env.PUBLIC_IP} \
                        "echo Connected"
                    """
                }
            }
        }

        stage('AMI Scan') {
            steps {
                script {
                    echo "Running Trivy Scan..."

                    def scanStatus = sh(
                        script: """
                            ssh -i ${env.PEM_FILE} \
                            -o StrictHostKeyChecking=no \
                            ubuntu@${env.PUBLIC_IP} "
                                
                                # Run scan with timeout protection
                                trivy rootfs / \
                                --scanners vuln \
                                --severity HIGH,CRITICAL \
                                --ignore-unfixed \
                                --timeout 15m \
                                --skip-dirs /var/lib/jenkins,/usr/share,/tmp \
                                --format json \
                                --output /tmp/${env.TRIVY_REPORT} \
                                --exit-code 1 || echo 'TRIVY_FAILED'

                                # Ensure file always exists
                                if [ ! -f /tmp/${env.TRIVY_REPORT} ]; then
                                    echo '{}' > /tmp/${env.TRIVY_REPORT}
                                fi
                            "
                        """,
                        returnStatus: true
                    )

                    // Always try to copy report
                    sh """
                        scp -i ${env.PEM_FILE} \
                        -o StrictHostKeyChecking=no \
                        ubuntu@${env.PUBLIC_IP}:/tmp/${env.TRIVY_REPORT} \
                        ${env.WORKSPACE}/${env.TRIVY_REPORT}
                    """

                    // Fail pipeline ONLY for vulnerabilities (not timeout crash)
                    if (scanStatus != 0) {
                        error("Trivy detected HIGH/CRITICAL vulnerabilities OR scan failed.")
                    }
                }
            }
        }
    }
    post {

        always {
            script {
                if (env.INSTANCE_ID) {
                    echo "Terminating EC2 instance: ${env.INSTANCE_ID}"
                    sh """
                        aws ec2 terminate-instances \
                        --instance-ids ${env.INSTANCE_ID} \
                        --region ${env.REGION}
                    """
                } else {
                    echo "No EC2 instance to terminate."
                }
            }

            archiveArtifacts artifacts: "${env.TRIVY_REPORT}",
                             allowEmptyArchive: true,
                             fingerprint: true
        }

        success {
            script {
                try {
                    slackSend(
                        channel: env.SLACK_CHANNEL,
                        color: "good",
                        message: """\
                        AMI Scan Pipeline SUCCESS
                        *Job:* ${env.JOB_NAME}
                        *Build:* #${env.BUILD_NUMBER}
                        *AMI:* ${env.AMI_ID}
                        *Instance:* ${env.INSTANCE_ID}
                        *Report:* ${env.BUILD_URL}artifact/${env.TRIVY_REPORT}
                        *URL:* ${env.BUILD_URL}"""
                    )
                } catch (Exception e) {
                    // added  failure handling
                    echo "Slack notification failed: ${e.message}"
                }
            }
        }

        failure {
            script {
                try {
                    slackSend(
                        channel: env.SLACK_CHANNEL,
                        color: "danger",
                        message: """\
                        AMI Scan Pipeline FAILED
                        *Job:* ${env.JOB_NAME}
                        *Build:* #${env.BUILD_NUMBER}
                        *AMI:* ${env.AMI_ID}
                        *Instance:* ${env.INSTANCE_ID ?: 'N/A'}
                        *Logs:* ${env.BUILD_URL}console
                        *URL:* ${env.BUILD_URL}"""
                    )
                } catch (Exception e) {
                    echo "Slack notification failed: ${e.message}"
                }
            }
        }
    }
}